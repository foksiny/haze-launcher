{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "../../out/main",
    "rootDir": "..",
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": [".", "../shared/**/*"]
}
